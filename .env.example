# ============================================
# IBM watsonx.ai credentials (REQUIRED)
# Get these from https://cloud.ibm.com/iam/apikeys
# and your watsonx.ai project "Manage" tab
# ============================================
WATSONX_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# watsonx.ai regional endpoint (change if your project is in a different region)
# us-south (Dallas) | eu-de (Frankfurt) | eu-gb (London) | jp-tok (Tokyo)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# IBM Granite model to use for generation
# Options: ibm/granite-3-8b-instruct | ibm/granite-3-2b-instruct | ibm/granite-13b-instruct-v2
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# IBM IAM token endpoint (rarely needs changing)
IBM_IAM_URL=https://iam.cloud.ibm.com/identity/token

# ============================================
# App config
# ============================================
PORT=5000
JWT_SECRET=change_this_to_a_long_random_string
NODE_ENV=development
